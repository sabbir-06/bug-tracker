pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            environment {
                HOME = "${WORKSPACE}"
                GOPATH = "${WORKSPACE}/.go"
                GOMODCACHE = "${WORKSPACE}/.go/pkg/mod"
                XDG_CACHE_HOME = "${WORKSPACE}/.cache"
                GOCACHE = "${WORKSPACE}/.cache/go-build"
            }
            steps {
                dir('bugtracker-backend') {
                    sh '''
                    mkdir -p "$GOPATH" "$GOMODCACHE" "$XDG_CACHE_HOME" "$GOCACHE"
                    go test ./... -v 2>&1 | go-junit-report -set-exit-code > report.xml
                    go test ./... -covermode=atomic -coverprofile=coverage.out
                    go tool cover -html=coverage.out -o coverage.html
                    mkdir -p reports
                    mv coverage.html reports/
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-backend/report.xml'
                    publishHTML target: [
                        reportDir: 'bugtracker-backend/reports',
                        reportFiles: 'coverage.html',
                        reportName: 'Backend Coverage Report'
                    ]
                }
            }
        }

        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') {
                    sh '''
                    npm ci
                    npm test
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-frontend/test-results.xml'
                }
            }
        }
    }
}
